homelab-dump.txt

# Never commit a plaintext vault — only the ansible-vault encrypted version
# ansible/vars/vault.yml must be encrypted before committing
ansible/vars/vault.yml.plaintext
ansible/vars/vault.yml.tmp
/tmp/*-vault.yml

# Obsidian local vault metadata — machine-specific, not for version control
.obsidian/
docs/.obsidian/
